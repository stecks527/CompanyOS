function openCompanyOS() {
  companyOSEnsureDatabase_();

  const html = HtmlService
    .createTemplateFromFile("CompanyOSDialog")
    .evaluate()
    .setWidth(1180)
    .setHeight(760);

  SpreadsheetApp.getUi().showModalDialog(
    html,
    productionUIDialogTitle_("Company Roster")
  );
}

function launchCompanyOS() {
  openCompanyOS();
}
