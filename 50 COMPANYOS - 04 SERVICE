function previewCompanyOSMigrationFromDialog() {
  const lock = LockService.getScriptLock();

  if (!lock.tryLock(5000)) {
    throw new Error(
      "CompanyOS is already building a migration preview. Please wait for it to finish."
    );
  }

  try {
    const result = companyOSBuildContactSheetMigrationPreview_();

    return {
      success: true,
      ready: true,
      totalRows: Number(result.totalRows || 0),
      createCount: Number(result.createCount || 0),
      updateCount: Number(result.updateCount || 0),
      warningCount: Number(result.warningCount || 0)
    };

  } finally {
    lock.releaseLock();
  }
}

function executeCompanyOSMigrationFromDialog() {
  const result = executeCompanyOSContactSheetMigration();
  return {
    success: true,
    result: result,
    roster: companyOSGetRosterState_()
  };
}

