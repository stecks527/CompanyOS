function repairCompanyOSPeopleRows() {
  const engine = companyOSGetEngineWorkbook_();
  const sheet = engine.getSheetByName(
    COMPANYOS_CONFIG.SHEETS.PEOPLE
  );

  if (!sheet) {
    throw new Error('Could not find "CompanyOS People".');
  }

  const values = sheet.getDataRange().getValues();

  if (!values.length) {
    throw new Error("CompanyOS People has no header row.");
  }

  const headers = values[0];
  const memberIdIndex = headers.indexOf("Member ID");

  if (memberIdIndex < 0) {
    throw new Error(
      'CompanyOS People is missing the "Member ID" header.'
    );
  }

  const memberRows = values
    .slice(1)
    .filter(function(row) {
      return companyOSClean_(row[memberIdIndex]);
    });

  if (!memberRows.length) {
    throw new Error(
      "No populated CompanyOS member records were found."
    );
  }

  const timestamp = Utilities.formatDate(
    new Date(),
    Session.getScriptTimeZone(),
    "yyyyMMdd_HHmmss"
  );

  sheet
    .copyTo(engine)
    .setName(
      "CompanyOS People Before Row Repair " +
      timestamp
    );

  /*
   * Remove the entire current body, including FALSE values
   * created by checkbox validation.
   */
  sheet
    .getRange(
      2,
      1,
      sheet.getMaxRows() - 1,
      sheet.getMaxColumns()
    )
    .clear({
      contentsOnly: true
    });

  /*
   * Write the real members directly below the header.
   */
  sheet
    .getRange(
      2,
      1,
      memberRows.length,
      headers.length
    )
    .setValues(memberRows)
    .setFontFamily("Arial");

  SpreadsheetApp.flush();

  Logger.log(
    "CompanyOS row repair complete. Members moved: " +
    memberRows.length
  );

  return {
    success: true,
    membersMoved: memberRows.length,
    firstMemberRow: 2,
    lastMemberRow: memberRows.length + 1
  };
}

