/*************************************************
 * SETTINGS + SOURCE HELPERS
 *************************************************/

function companyOSResponseGetSetting_(settingName) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const settingsSheet = ss.getSheetByName(
    COMPANYOS_RESPONSE.SETTINGS_SHEET_NAME
  );

  if (!settingsSheet) {
    throw new Error(
      'Could not find the "' +
        COMPANYOS_RESPONSE.SETTINGS_SHEET_NAME +
        '" sheet.'
    );
  }

  const values = settingsSheet.getDataRange().getDisplayValues();
  const wanted = companyOSResponseNormalizeSettingLabel_(settingName);

  for (let row = 0; row < values.length; row++) {
    for (let column = 0; column < values[row].length; column++) {
      const currentLabel =
        companyOSResponseNormalizeSettingLabel_(values[row][column]);

      if (currentLabel !== wanted) continue;

      const settingValue =
        column + 1 < values[row].length
          ? String(values[row][column + 1] || "").trim()
          : "";

      if (!settingValue) {
        throw new Error(
          'The Settings entry "' +
            settingName +
            '" does not have a value in the cell immediately to its right.'
        );
      }

      return settingValue;
    }
  }

  throw new Error(
    'Could not find the Settings entry "' + settingName + '".'
  );
}


function companyOSResponseNormalizeSettingLabel_(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .replace(/\s+/g, " ");
}


function companyOSResponseExtractGoogleId_(value) {
  const text = String(value || "").trim();

  if (!text) return "";

  const documentMatch = text.match(/\/d\/([a-zA-Z0-9_-]+)/);
  if (documentMatch) return documentMatch[1];

  const folderMatch = text.match(/\/folders\/([a-zA-Z0-9_-]+)/);
  if (folderMatch) return folderMatch[1];

  if (/^[a-zA-Z0-9_-]{20,}$/.test(text)) return text;

  throw new Error(
    "Could not extract a Google resource ID from:\n" + text
  );
}


function companyOSResponseGetSources_() {
  const mainSS = SpreadsheetApp.getActiveSpreadsheet();

  const engineResource = companyOSResponseGetSetting_(
    "Engine Workbook"
  );

  const responseResource = companyOSResponseGetSetting_(
    COMPANYOS_RESPONSE.RESPONSE_RESOURCE_SETTING
  );

  const engineSpreadsheetId =
    companyOSResponseExtractGoogleId_(engineResource);

  const responseSpreadsheetId =
    companyOSResponseExtractGoogleId_(responseResource);

  let engineSS;
  let responseSS;

  try {
    engineSS = SpreadsheetApp.openById(
      engineSpreadsheetId
    );
  } catch (error) {
    throw new Error(
      'Could not open the spreadsheet listed under "Engine Workbook" in Settings.\n\n' +
        (error && error.message ? error.message : error)
    );
  }

  try {
    responseSS = SpreadsheetApp.openById(
      responseSpreadsheetId
    );
  } catch (error) {
    throw new Error(
      'Could not open the spreadsheet listed under "' +
        COMPANYOS_RESPONSE.RESPONSE_RESOURCE_SETTING +
        '" in Settings.\n\n' +
        (error && error.message ? error.message : error)
    );
  }

  const peopleSheet = engineSS.getSheetByName(
    COMPANYOS_RESPONSE.PEOPLE_SHEET_NAME
  );

  if (!peopleSheet) {
    throw new Error(
      'Could not find "' +
        COMPANYOS_RESPONSE.PEOPLE_SHEET_NAME +
        '" in the Engine workbook.'
    );
  }

  const responseSheet = responseSS.getSheetByName(
    COMPANYOS_RESPONSE.RESPONSE_SHEET_NAME
  );

  if (!responseSheet) {
    throw new Error(
      'Could not find "' +
        COMPANYOS_RESPONSE.RESPONSE_SHEET_NAME +
        '" in the Emergency Info Form workbook.'
    );
  }

  return {
    mainSS: mainSS,
    companySS: engineSS,
    engineSS: engineSS,
    peopleSheet: peopleSheet,
    responseSS: responseSS,
    responseSheet: responseSheet
  };
}

/**
 * Add this item to your existing CompanyOS menu.
 *
 * Example:
 * menu.addItem(
 *   "Sync Responses",
 *   "companyOSOpenResponseSync"
 * );
 */
function companyOSOpenResponseSync() {
  const template = HtmlService.createTemplateFromFile(
    "53 COMPANYOS RESPONSE - HTML"
  );

  template.initialPayload = companyOSBuildResponsePreview_();

  const html = template
    .evaluate()
    .setWidth(COMPANYOS_RESPONSE.DIALOG_WIDTH)
    .setHeight(COMPANYOS_RESPONSE.DIALOG_HEIGHT);

  SpreadsheetApp.getUi().showModalDialog(
    html,
    COMPANYOS_RESPONSE.DIALOG_TITLE
  );
}


