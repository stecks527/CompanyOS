function companyOSOpenHeadshotSync() {
  const template = HtmlService.createTemplateFromFile(
    "54 COMPANYOS HEADSHOTS - HTML"
  );

  template.initialPayload = companyOSBuildHeadshotPreview_();

  const html = template
    .evaluate()
    .setWidth(COMPANYOS_HEADSHOTS.DIALOG_WIDTH)
    .setHeight(COMPANYOS_HEADSHOTS.DIALOG_HEIGHT);

  SpreadsheetApp.getUi().showModalDialog(
    html,
    COMPANYOS_HEADSHOTS.DIALOG_TITLE
  );
}


