const COMPANYOS_HEADSHOTS = Object.freeze({
  SETTINGS_SHEET_NAME: "Production Settings",
  ENGINE_SETTING: "Engine Workbook",
  ROOT_FOLDER_SETTING: "Main Headshot Folder",

  PEOPLE_SHEET_NAME: "CompanyOS People",
  LOG_SHEET_NAME: "CompanyOS Headshot Log",

  DIALOG_TITLE: "CompanyOS Headshot Sync",
  DIALOG_WIDTH: 1120,
  DIALOG_HEIGHT: 780,

  PEOPLE_HEADERS: Object.freeze({
    MEMBER_ID: "Member ID",
    LEGAL_NAME: "Legal Name",
    PROFESSIONAL_NAME: "Professional / Union Name",
    DISPLAY_NAME: "Display Name",

    // The sync supports any of these existing CompanyOS layouts.
    COMBINED_HEADSHOT: "Headshot URL / File ID",
    FILE_ID: "Headshot File ID",
    URL: "Headshot URL"
  }),

  IMAGE_EXTENSIONS: Object.freeze([
    "jpg",
    "jpeg",
    "png",
    "webp",
    "gif",
    "heic"
  ])
});


