function companyOSGetEngineWorkbook_() {
  return SpreadsheetApp.openById(COMPANYOS_CONFIG.ENGINE_WORKBOOK_ID);
}

function companyOSGetPeopleSheet_() {
  companyOSEnsureDatabase_();
  return companyOSGetEngineWorkbook_()
    .getSheetByName(COMPANYOS_CONFIG.SHEETS.PEOPLE);
}

function companyOSNextMemberId_(values, map) {
  let max = 0;

  (values || []).slice(1).forEach(function(row) {
    const value = companyOSClean_(row[map["Member ID"]]);
    const match = value.match(/^CMP-(\d+)$/i);
    if (match) max = Math.max(max, Number(match[1]));
  });

  return "CMP-" + String(max + 1).padStart(4, "0");
}

function companyOSArchiveMember_(memberId) {
  const member = companyOSGetMember_(memberId);
  if (!member) throw new Error("Company member not found.");

  member.status = "Inactive";
  return companyOSSaveMember_(member);
}

function companyOSReactivateMember_(memberId) {
  const member = companyOSGetMember_(memberId);
  if (!member) throw new Error("Company member not found.");

  member.status = "Active";
  member.archivedAt = "";
  return companyOSSaveMember_(member);
}

function companyOSBuildHeaderMap_(headers) {
  return companyOSHeaderMap_(headers);
}

function companyOSBoolean_(value) {
  return companyOSBool_(value);
}

function diagnoseCompanyOSPeopleLocation() {
  const configuredId =
    COMPANYOS_CONFIG.ENGINE_WORKBOOK_ID;

  const engine =
    SpreadsheetApp.openById(configuredId);

  const peopleSheet =
    engine.getSheetByName(
      COMPANYOS_CONFIG.SHEETS.PEOPLE
    );

  if (!peopleSheet) {
    throw new Error(
      'No "' +
      COMPANYOS_CONFIG.SHEETS.PEOPLE +
      '" sheet exists in the configured Engine workbook.'
    );
  }

  const values =
    peopleSheet.getDataRange().getValues();

  const headers =
    values.length ? values[0] : [];

  const memberIdColumn =
    headers.indexOf("Member ID");

  let populatedMemberIds = 0;

  if (memberIdColumn >= 0) {
    populatedMemberIds =
      values
        .slice(1)
        .filter(function(row) {
          return String(
            row[memberIdColumn] || ""
          ).trim();
        })
        .length;
  }

  const message = [
    "COMPANYOS LOCATION DIAGNOSTIC",
    "",
    "Workbook Name:",
    engine.getName(),
    "",
    "Configured Workbook ID:",
    configuredId,
    "",
    "Workbook URL:",
    engine.getUrl(),
    "",
    "People Sheet:",
    peopleSheet.getName(),
    "",
    "Last Row:",
    peopleSheet.getLastRow(),
    "",
    "Populated Member IDs:",
    populatedMemberIds
  ].join("\n");

  Logger.log(message);

  SpreadsheetApp.getUi().alert(message);

  return {
    workbookName: engine.getName(),
    workbookId: configuredId,
    workbookUrl: engine.getUrl(),
    peopleSheet: peopleSheet.getName(),
    lastRow: peopleSheet.getLastRow(),
    populatedMemberIds: populatedMemberIds
  };
}
